pipeline {
    agent any
    stages {
        stage("hello") {
            steps {
                echo "hello world"
            }
        }
        stage("date and time by using java") {
            steps {
                script {
                    def date = new Date().format("YYYY-MM-dd HH:mm:SS")
                    println date
                }
            }
        }
        stage("github") {
            steps {
                git url: "git_url", branch: "branch_name"
            }
        }
        stage("list github content") {
            steps {
                echo "listing github content"
                sh "ls -r"
            }
        }
    }
}

