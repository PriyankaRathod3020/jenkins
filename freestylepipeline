/*
This is a freestyle pipeline. 
1. printing hello world
2. printing date
3. cloning github repo and listing its content
4. we can periodically scehdule the pipleine by using "Build periodically" under "Triggers"
*/
pipeline {
    agent any
    stages {
        stage("hello") {
            steps {
                echo "hello world"
            }
        }
        stage("date and time by using java") {
            steps {
                script {
                    def date = new Date().format("YYYY-MM-dd HH:mm:SS")
                    println date
                }
            }
        }
        stage("github") {
            steps {
                git url: "https://github.com/PriyankaRathod3020/ShellScript.git", branch: "basic"
            }
        }
        stage("list github content") {
            steps {
                echo "listing github content"
                sh "ls -r"
            }
        }
    }
}

