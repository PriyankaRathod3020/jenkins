/* Below line of code is wriitten in Build Steps Section of freestyle project
1. Copied the python docker app into jenkins path -  /var/lib/jenkins/workspace/py_app
2. added jenkins user to docker group
3. then build and run the container using below commands to run the container
*/

cd /var/lib/jenkins/workspace/py_app
docker build -t python_app .
docker run -d -p 5000:5000 --name "python_container" python_app:latest
